APP_NAME=Nelna Python API
APP_ENV=development
APP_PORT=8000
LOG_LEVEL=INFO

# ---- Database (PostgreSQL) ----
# asyncpg driver prefix required for Python; omit +asyncpg for Prisma/Node
DATABASE_URL=postgresql+asyncpg://nelna_user:NelnaPass@2024@localhost:5432/nelna_maintenance

# Shared vars used by docker-compose postgres service
POSTGRES_USER=nelna_user
POSTGRES_PASSWORD=NelnaPass@2024
POSTGRES_DB=nelna_maintenance
POSTGRES_PORT=5432

# ---- Redis ----
REDIS_URL=redis://localhost:6379/0

# ---- JWT (must match Node.js backend — same secret) ----
# These are REQUIRED.  The stack will refuse to start without them.
JWT_SECRET=REPLACE_ME_WITH_A_STRONG_SECRET_64_CHARS_MIN
JWT_REFRESH_SECRET=REPLACE_ME_WITH_A_DIFFERENT_STRONG_SECRET
JWT_EXPIRE=24h
JWT_REFRESH_EXPIRE=7d

# ---- Legacy Node backend URL (compat proxy) ----
LEGACY_API_URL=http://localhost:3000

# ---- Throughput tuning ----
MAX_BATCH_SIZE=1000
REDIS_STREAM_KEY=nelna:collect:events
PROXY_TIMEOUT_SECONDS=30
GUNICORN_WORKERS=4

# ---- Rate limiting ----
RATE_LIMIT_COLLECT=200/minute

# ---- pgAdmin (development profile only) ----
PGADMIN_EMAIL=admin@nelna.local
PGADMIN_PASSWORD=NelnaAdmin@2024
PGADMIN_PORT=8081
