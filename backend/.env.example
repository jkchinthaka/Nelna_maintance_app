# ============================================================================
# NELNA MAINTENANCE MANAGEMENT SYSTEM - Environment Configuration
# ============================================================================

# Application
NODE_ENV=development
PORT=3000
APP_NAME=Nelna Maintenance System
APP_VERSION=1.0.0

# Database (PostgreSQL)
# Local:   postgresql://nelna_user:NelnaPass@2024@localhost:5432/nelna_maintenance
# Supabase: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://nelna_user:CHANGE_ME@localhost:5432/nelna_maintenance

# MongoDB (main_app)
MAIN_APP_MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.gsqzhij.mongodb.net/main_app?appName=Cluster0
MAIN_APP_MONGODB_DB_NAME=main_app

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production-min-32-chars
JWT_EXPIRY=24h
JWT_REFRESH_EXPIRY=7d

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:8080

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# File Upload
UPLOAD_MAX_SIZE=10485760
UPLOAD_PATH=./uploads

# Logging
LOG_LEVEL=debug
LOG_DIR=./logs

# Firebase (FCM Notifications)
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@nelna.com

# Error Monitoring (Sentry)
# Create a Node.js project at https://sentry.io and paste the DSN here.
# Leave blank to disable Sentry entirely.
SENTRY_DSN_NODE=
SENTRY_TRACES_SAMPLE_RATE=0.2
SENTRY_PROFILES_SAMPLE_RATE=0.1
