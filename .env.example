# ===========================================================
# Nelna Maintenance Management System - Environment Variables
# Copy this file as .env and fill in the values
# ===========================================================

# ==================== General ====================
NODE_ENV=development

# ==================== PostgreSQL ====================
POSTGRES_USER=nelna_user
POSTGRES_PASSWORD=NelnaPass@2024
POSTGRES_DB=nelna_maintenance
POSTGRES_PORT=5432

# ==================== Redis ====================
REDIS_PORT=6379

# ==================== API ====================
API_PORT=3000
JWT_SECRET=your-super-secret-jwt-key-change-me
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-me
JWT_EXPIRE=24h
JWT_REFRESH_EXPIRE=7d
CORS_ORIGIN=http://localhost:8080
LOG_LEVEL=info
MAX_FILE_SIZE=10485760

# ==================== Nginx ====================
NGINX_PORT=8080
NGINX_SSL_PORT=8443

# ==================== pgAdmin (development only) ====================
PGADMIN_EMAIL=admin@nelna.local
PGADMIN_PASSWORD=NelnaAdmin@2024
PGADMIN_PORT=8081
